# ==========================================
# LoopIn - Environment Variables Configuration
# ==========================================

# --- Base n8n Configuration ---
GENERIC_TIMEZONE=Europe/Rome

# --- Network & Webhook Configuration ---
# Phase 1 (Locale/Test): Insert the URL generated in the cloudflared logs (e.g. https://random-word.trycloudflare.com)
# Phase 2 (Production): Insert your real domain (e.g. https://n8n.yourdomain.com)
WEBHOOK_URL=https://random-word.trycloudflare.com

# --- Host Settings (Primarily for Production) ---
N8N_HOST=n8n.yourdomain.com
N8N_PORT=5678
N8N_PROTOCOL=https

# Security Note: The API keys (Anthropic, Telegram, LinkedIn, GitHub) 
# will not be inserted in this file. They will be configured securely 
# inside the n8n graphical interface (Credential Manager) in order to be encrypted in the n8n SQLite database.